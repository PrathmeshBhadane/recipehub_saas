# RecipeHUB Environment Configurations

# Database URLs
# For Docker Compose, keep these defaults.
# For running locally outside docker connecting to docker databases, use localhost:
# DATABASE_URL=postgresql://recipeuser:recipepassword@localhost:5432/recipehub
# REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://recipeuser:recipepassword@db:5432/recipehub
REDIS_URL=redis://cache:6379/0

# Security
JWT_SECRET=supersecretjwtkeyrecipehub2026version123
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Settings
# Set to your Grok (xAI) API key (e.g. xai-...) to activate real LLM generation
# If left as mock_key, the application runs a local mock parser.
AI_API_KEY=mock_key
AI_BASE_URL=https://api.x.ai/v1
AI_MODEL=grok-2

# Frontend URL Configuration (for CORS)
VITE_API_URL=http://localhost:8000
